# Public Data Portal decoding key. Never commit the real value.
OPEN_API_SERVICE_KEY=replace-me

# Local Docker Compose database. GitHub Actions needs a reachable hosted PostGIS URL.
DATABASE_URL=postgresql://safety_zone:safety_zone@localhost:5432/safety_zone

# MVP example only. Replace with the complete set of 5-digit district codes to monitor.
SGG_CODES=11110,11140,11170

# Optional. Set one or both notification channels.
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional tuning.
API_NUM_ROWS=1000
API_REQUEST_DELAY_SECONDS=0.2
API_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

