# Public Data Portal decoding key. Never commit the real value.
OPEN_API_SERVICE_KEY=replace-me

# Existing mobility PostGIS (D:\standard-node-link-postgis, host port 5433).
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres:replace-me@localhost:5433/mobility_db

# MVP example only. Replace with the complete 5-digit district-code scope.
SGG_CODES=11110,11140,11170

# Optional notification channels.
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional API tuning.
API_NUM_ROWS=1000
API_REQUEST_DELAY_SECONDS=0.2
API_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

